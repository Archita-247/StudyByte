GROQ_API_KEY=
EMAIL_USER=
EMAIL_PASS=

# OTP security settings
OTP_HASH_SECRET=replace-with-a-long-random-secret
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Use "firestore" in production. Leave unset for local file-backed development.
OTP_STORE=firestore

# Option A: JSON string service account for Firestore OTP storage.
FIREBASE_SERVICE_ACCOUNT=

# Option B: use Google Application Default Credentials instead of FIREBASE_SERVICE_ACCOUNT.
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
